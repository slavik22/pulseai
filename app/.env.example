# Copy to .env and fill in your values

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://pulseai:pulseai@localhost:5432/pulseai
DATABASE_URL_SYNC=postgresql+psycopg2://pulseai:pulseai@localhost:5432/pulseai

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG tuning (optional)
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_MIN_SIMILARITY=0.60

# App
APP_ENV=development
LOG_LEVEL=INFO
